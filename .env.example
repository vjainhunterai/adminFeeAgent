# =============================================================
# AdminFee Application Environment Variables
# =============================================================
# Copy this to .env and fill in the values:
#   cp .env.example .env
# =============================================================

# --- MySQL Database ---
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=joblog_metadata

# --- Ollama LLM Server ---
LLM_BASE_URL=http://172.31.27.7:11434
LLM_MODEL=llama3.1:8b

# --- S3 Bucket (input/output) ---
S3_BUCKET=etlhunter
S3_INPUT_KEY=adminfee_input/input_template.xlsx
S3_OUTPUT_PREFIX=adminfee_output

# --- SSH / Airflow (paramiko) ---
SSH_HOST=172.31.25.132
SSH_USERNAME=ubuntu
# Path INSIDE the container (mounted via docker-compose volume)
SSH_KEY_PATH=/app/secrets/airflow.pem
AIRFLOW_START_CMD=bash start_airflow.sh
AIRFLOW_TRIGGER_CMD=/home/ubuntu/run_airflow.sh dags trigger execute_adminFee_Data_Pipeline_v1
